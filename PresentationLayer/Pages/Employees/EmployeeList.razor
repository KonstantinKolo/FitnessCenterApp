@page "/employees"
@inject EmployeeContext employeeContext
@inject FitnessCenterContext fitnessCenterContext

<h3>Employees</h3>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible fade show">
        @message
        <button type="button" class="btn-close" @onclick="() => message = null"></button>
    </div>
}

<button class="btn btn-success mb-3" @onclick="ShowCreateForm">+ Add Employee</button>

@if (showForm)
{
    <div class="card mb-3">
        <div class="card-header">@(editingId == null ? "Create New Employee" : "Edit Employee")</div>
        <div class="card-body">
            <EditForm Model="@formModel" OnValidSubmit="Save">
                <DataAnnotationsValidator />
                <div class="mb-3">
                    <label class="form-label">First Name</label>
                    <InputText class="form-control" @bind-Value="formModel.FirstName" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Last Name</label>
                    <InputText class="form-control" @bind-Value="formModel.LastName" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <InputText class="form-control" type="password" @bind-Value="formModel.Password" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Workplace</label>
                    <InputSelect class="form-select" @bind-Value="formModel.WorkplaceId">
                        <option value="0">-- Select --</option>
                        @if (fitnessCenters != null)
                        {
                            @foreach (var fc in fitnessCenters)
                            {
                                <option value="@fc.Id">@fc.Name - @fc.Address</option>
                            }
                        }
                    </InputSelect>
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
                <button type="button" class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
            </EditForm>
        </div>
    </div>
}

@if (employees == null)
{
    <p>Loading...</p>
}
else if (employees.Count == 0)
{
    <p>No employees found.</p>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr><th>ID</th><th>First Name</th><th>Last Name</th><th>Workplace</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var e in employees)
            {
                <tr>
                    <td>@e.Id</td><td>@e.FirstName</td><td>@e.LastName</td>
                    <td>@(e.Workplace?.Name ?? "N/A")</td>
                    <td>
                        <button class="btn btn-sm btn-warning" @onclick="() => Edit(e)">Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => Delete(e.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Employee> employees;
    private List<FitnessCenter> fitnessCenters;
    private string message;
    private bool isError, showForm;
    private int? editingId;
    private EmployeeFormModel formModel = new();

    public class EmployeeFormModel
    {
        public string FirstName { get; set; }
        public string LastName { get; set; }
        public string Password { get; set; }
        public int WorkplaceId { get; set; }
    }

    protected override void OnInitialized()
    {
        Load();
        try { fitnessCenters = fitnessCenterContext.ReadAll(false, true); } catch { fitnessCenters = new List<FitnessCenter>(); }
    }

    private void Load()
    {
        try { employees = employeeContext.ReadAll(true, true); }
        catch (Exception ex) { message = "Error: " + ex.Message; isError = true; }
    }

    private void ShowCreateForm() { editingId = null; formModel = new EmployeeFormModel(); showForm = true; }

    private void Edit(Employee e)
    {
        editingId = e.Id;
        formModel = new EmployeeFormModel { FirstName = e.FirstName, LastName = e.LastName, Password = e.Password, WorkplaceId = e.Workplace?.Id ?? 0 };
        showForm = true;
    }

    private void Save()
    {
        try
        {
            if (formModel.WorkplaceId == 0) { message = "Select a workplace!"; isError = true; return; }
            FitnessCenter workplace = fitnessCenterContext.Read(formModel.WorkplaceId);
            if (editingId == null)
            {
                employeeContext.Create(new Employee(formModel.FirstName, formModel.LastName, formModel.Password, workplace));
                message = "Employee created!";
            }
            else
            {
                Employee emp = employeeContext.Read(editingId.Value, true);
                emp.FirstName = formModel.FirstName; emp.LastName = formModel.LastName;
                emp.Password = formModel.Password; emp.Workplace = workplace;
                employeeContext.Update(emp, true);
                message = "Employee updated!";
            }
            isError = false; showForm = false; Load();
        }
        catch (Exception ex) { message = "Error: " + ex.Message; isError = true; }
    }

    private void Delete(int id)
    {
        try { employeeContext.Delete(id); message = "Deleted!"; isError = false; Load(); }
        catch (Exception ex) { message = "Error: " + ex.Message; isError = true; }
    }

    private void CancelForm() { showForm = false; }
}