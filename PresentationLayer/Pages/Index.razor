@page "/"

<h3>Fitness Center Management System</h3>
<p>Welcome! Use the navigation menu to manage your fitness center data.</p>

<div class="row mt-4">
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Members</h5>
                <p class="card-text">Manage gym members and their information.</p>
                <a href="/members" class="btn btn-primary">Go to Members</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Memberships</h5>
                <p class="card-text">View and manage membership plans.</p>
                <a href="/memberships" class="btn btn-primary">Go to Memberships</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Employees</h5>
                <p class="card-text">Manage fitness center staff.</p>
                <a href="/employees" class="btn btn-primary">Go to Employees</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Fitness Centers</h5>
                <p class="card-text">Manage fitness center locations.</p>
                <a href="/fitnesscenters" class="btn btn-primary">Go to Fitness Centers</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Payments</h5>
                <p class="card-text">Track and manage payments.</p>
                <a href="/payments" class="btn btn-primary">Go to Payments</a>
            </div>
        </div>
    </div>
</div>
