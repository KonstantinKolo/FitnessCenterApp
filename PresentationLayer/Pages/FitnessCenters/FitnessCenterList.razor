@page "/fitnesscenters"
@inject FitnessCenterContext fitnessCenterContext

<h3>Fitness Centers</h3>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible fade show">
        @message
        <button type="button" class="btn-close" @onclick="() => message = null"></button>
    </div>
}

<button class="btn btn-success mb-3" @onclick="ShowCreateForm">+ Add Fitness Center</button>

@if (showForm)
{
    <div class="card mb-3">
        <div class="card-header">@(editingId == null ? "Create New Fitness Center" : "Edit Fitness Center")</div>
        <div class="card-body">
            <EditForm Model="@formModel" OnValidSubmit="Save">
                <DataAnnotationsValidator />
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <InputText class="form-control" @bind-Value="formModel.Name" />
                    <ValidationMessage For="@(() => formModel.Name)" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Address</label>
                    <InputText class="form-control" @bind-Value="formModel.Address" />
                    <ValidationMessage For="@(() => formModel.Address)" />
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
                <button type="button" class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
            </EditForm>
        </div>
    </div>
}

@if (centers == null)
{
    <p>Loading...</p>
}
else if (centers.Count == 0)
{
    <p>No fitness centers found.</p>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr><th>ID</th><th>Name</th><th>Address</th><th>Employees</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var c in centers)
            {
                <tr>
                    <td>@c.Id</td>
                    <td>@c.Name</td>
                    <td>@c.Address</td>
                    <td>@(c.EmployeesList?.Count ?? 0)</td>
                    <td>
                        <button class="btn btn-sm btn-warning" @onclick="() => Edit(c)">Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => Delete(c.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<FitnessCenter> centers;
    private string message;
    private bool isError, showForm;
    private int? editingId;
    private FCFormModel formModel = new();

    public class FCFormModel
    {
        public string Name { get; set; }
        public string Address { get; set; }
    }

    protected override void OnInitialized() { Load(); }

    private void Load()
    {
        try { centers = fitnessCenterContext.ReadAll(true, true); }
        catch (Exception ex) { message = "Error: " + ex.Message; isError = true; }
    }

    private void ShowCreateForm() { editingId = null; formModel = new FCFormModel(); showForm = true; }

    private void Edit(FitnessCenter c)
    {
        editingId = c.Id;
        formModel = new FCFormModel { Name = c.Name, Address = c.Address };
        showForm = true;
    }

    private void Save()
    {
        try
        {
            if (editingId == null)
            {
                fitnessCenterContext.Create(new FitnessCenter(formModel.Address, formModel.Name));
                message = "Fitness Center created!";
            }
            else
            {
                FitnessCenter fc = fitnessCenterContext.Read(editingId.Value, true);
                fc.Name = formModel.Name;
                fc.Address = formModel.Address;
                fitnessCenterContext.Update(fc, true);
                message = "Fitness Center updated!";
            }
            isError = false; showForm = false; Load();
        }
        catch (Exception ex) { message = "Error: " + ex.Message; isError = true; }
    }

    private void Delete(int id)
    {
        try { fitnessCenterContext.Delete(id); message = "Deleted!"; isError = false; Load(); }
        catch (Exception ex) { message = "Error: " + ex.Message; isError = true; }
    }

    private void CancelForm() { showForm = false; }
}
